{
  "name": "dwdb",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:create": "dotenv -e .env -- node-pg-migrate create --migrations-dir migrations",
    "migrate:up": "dotenv -e .env -- node-pg-migrate up --migrations-dir migrations",
    "migrate:down": "dotenv -e .env -- node-pg-migrate down --migrations-dir migrations"
  },
  "dependencies": {
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^5.1.0",
    "postgres": "^3.4.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.33.0",
    "@types/node": "^20.0.0",
    "dotenv-cli": "^8.0.0",
    "node-pg-migrate": "^7.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
